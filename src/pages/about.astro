---
import Base from '../layouts/Base.astro';
---

<Base title="About — public diary" description="About this site.">
  <div class="page-header">
    <h1>About</h1>
  </div>

  <div class="post-body">
    <p>
      This is a public diary. I write here when something is worth writing down —
      ideas, observations, things I've been reading or building.
